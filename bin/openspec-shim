#!/usr/bin/env python3
"""OpenSpec shim that runs automatic Codex OpenSpec Powers repair after init/update."""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


TEMPLATE = "codex-openspec-powers"
DEFAULT_SHARE_ROOT = Path.home() / ".local" / "share" / TEMPLATE
DEFAULT_STATE_FILE = DEFAULT_SHARE_ROOT / "state.json"


def state_file() -> Path:
    override = os.environ.get("OPSX_STATE_FILE")
    if override:
        return Path(override).expanduser()
    return DEFAULT_STATE_FILE


def read_state() -> dict[str, object]:
    path = state_file()
    if path.exists():
        try:
            return json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            return {}
    return {}


def path_without(paths_to_skip: set[Path]) -> str:
    entries: list[str] = []
    for entry in os.environ.get("PATH", "").split(os.pathsep):
        if not entry:
            continue
        resolved = Path(entry).expanduser().resolve()
        if resolved in paths_to_skip:
            continue
        entries.append(entry)
    return os.pathsep.join(entries)


def find_real_openspec() -> str:
    env = os.environ.get("OPSX_REAL_OPENSPEC")
    if env and Path(env).exists():
        return env

    state = read_state()
    real = state.get("real_openspec")
    if real and Path(str(real)).exists():
        return str(real)

    current_dir = Path(__file__).resolve().parent
    found = shutil.which("openspec", path=path_without({current_dir}))
    if found:
        return found
    print("openspec shim: cannot find real OpenSpec CLI", file=sys.stderr)
    return "openspec"



def is_noop_command(args: list[str]) -> bool:
    if not args:
        return True
    if args[0] in {"--help", "-h", "--version", "version", "help"}:
        return True
    return any(arg in {"--help", "-h"} for arg in args[1:])

def option_value(args: list[str], option: str) -> str | None:
    prefix = option + "="
    for index, arg in enumerate(args):
        if arg.startswith(prefix):
            return arg.split("=", 1)[1]
        if arg == option and index + 1 < len(args):
            return args[index + 1]
    return None


def target_path(args: list[str]) -> Path:
    value_options = {"--tools", "--profile"}
    positional: list[str] = []
    index = 1
    while index < len(args):
        arg = args[index]
        if arg == "--":
            positional.extend(args[index + 1 :])
            break
        if arg in value_options:
            index += 2
            continue
        if any(arg.startswith(opt + "=") for opt in value_options):
            index += 1
            continue
        if arg.startswith("-"):
            index += 1
            continue
        positional.append(arg)
        index += 1
    return Path(positional[0]).expanduser().resolve() if positional else Path.cwd()


def should_repair(args: list[str], target: Path) -> bool:
    if is_noop_command(args):
        return False
    command = args[0]
    if command == "update":
        return True
    if command != "init":
        return False

    tools = option_value(args, "--tools")
    if tools is None:
        # Interactive init: repair only if Codex files appeared.
        return (target / ".codex").exists()
    selected = {part.strip() for part in tools.split(",") if part.strip()}
    return "codex" in selected or "all" in selected


def find_opsx() -> str | None:
    sibling = Path(__file__).resolve().with_name("opsx")
    if sibling.exists():
        return str(sibling)
    found = shutil.which("opsx")
    if found:
        return found
    state = read_state()
    bin_dir = state.get("bin_dir")
    if bin_dir:
        candidate = Path(str(bin_dir)) / "opsx"
        if candidate.exists():
            return str(candidate)
    return None


def run_auto_repair(target: Path) -> int:
    opsx = find_opsx()
    if not opsx:
        print("openspec shim: opsx not found; skipping overlay repair", file=sys.stderr)
        return 0
    share_root = os.environ.get("OPSX_SHARE_ROOT", str(DEFAULT_SHARE_ROOT))
    command = [
        opsx,
        "repair",
        "--yes",
        "--summary",
        "--root",
        str(target),
        "--source-root",
        share_root,
    ]
    print(f"{TEMPLATE}: auto-repair after OpenSpec command", flush=True)
    return subprocess.run(command, check=False).returncode


def main(argv: list[str] | None = None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    real = find_real_openspec()
    result = subprocess.run([real, *args], check=False)
    if result.returncode != 0:
        return result.returncode

    target = target_path(args)
    if should_repair(args, target):
        repair_code = run_auto_repair(target)
        if repair_code != 0:
            return repair_code
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
