#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/install-overlay <target-project> [--dry-run] [--force-overlay] [--force-config]

Safely installs the intent-driven Codex/OpenSpec overlay into a target project.
It copies overlay-owned files safely. By default different existing files are
reported and skipped; use --force-overlay for a Greenfield OpenSpec/Codex init
where generated placeholder prompts/skills should be replaced. Use --force-config
for openspec/config.yaml.
USAGE
}

[[ $# -gt 0 ]] || { usage >&2; exit 2; }
TARGET=""
DRY_RUN=0
FORCE_CONFIG=0
FORCE_OVERLAY=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run) DRY_RUN=1 ;;
    --force-overlay) FORCE_OVERLAY=1 ;;
    --force-config) FORCE_CONFIG=1 ;;
    -h|--help) usage; exit 0 ;;
    *)
      if [[ -z "$TARGET" ]]; then TARGET="$1"; else echo "Unexpected argument: $1" >&2; exit 2; fi
      ;;
  esac
  shift
done
[[ -n "$TARGET" ]] || { usage >&2; exit 2; }

SOURCE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="$(mkdir -p "$TARGET" && cd "$TARGET" && pwd)"

copy_file_no_overwrite() {
  local src="$1"
  local rel="$2"
  local force="${3:-0}"
  local dst="$TARGET/$rel"
  if [[ -e "$dst" ]]; then
    if cmp -s "$src" "$dst"; then
      echo "SKIP identical $rel"
      return 0
    fi
    if [[ "$force" == "1" ]]; then
      echo "REPLACE $rel"
      if [[ "$DRY_RUN" == "0" ]]; then
        mkdir -p "$(dirname "$dst")"
        cp "$src" "$dst"
      fi
      return 0
    fi
    echo "SKIP existing $rel"
    return 0
  fi
  echo "COPY $rel"
  if [[ "$DRY_RUN" == "0" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
  fi
}

copy_tree_no_overwrite() {
  local relroot="$1"
  local force="${2:-0}"
  while IFS= read -r -d '' src; do
    local rel="${src#$SOURCE/}"
    copy_file_no_overwrite "$src" "$rel" "$force"
  done < <(find "$SOURCE/$relroot" -type f -print0 | sort -z)
}

copy_tree_no_overwrite ".codex/prompts" "$FORCE_OVERLAY"
copy_tree_no_overwrite ".codex/skills" "$FORCE_OVERLAY"
copy_tree_no_overwrite "openspec/schemas/intent-driven" "$FORCE_OVERLAY"
copy_file_no_overwrite "$SOURCE/CONSTITUTION.md" "CONSTITUTION.md"
copy_file_no_overwrite "$SOURCE/ARCHITECTURE.md" "ARCHITECTURE.md"
copy_file_no_overwrite "$SOURCE/.secrets.example.env" ".secrets.example.env"
copy_file_no_overwrite "$SOURCE/openspec/README.md" "openspec/README.md" "$FORCE_OVERLAY"
copy_file_no_overwrite "$SOURCE/scripts/check-overlay" "scripts/check-overlay" "$FORCE_OVERLAY"
copy_file_no_overwrite "$SOURCE/AGENTS.md" "AGENTS.md" "$FORCE_OVERLAY"
copy_file_no_overwrite "$SOURCE/docs/lifecycle.md" "docs/intent-driven-lifecycle.md" "$FORCE_OVERLAY"
copy_file_no_overwrite "$SOURCE/docs/update-safety.md" "docs/intent-driven-update-safety.md" "$FORCE_OVERLAY"

if [[ ! -e "$TARGET/adr/README.md" ]]; then
  copy_file_no_overwrite "$SOURCE/adr/README.md" "adr/README.md" "$FORCE_OVERLAY"
else
  echo "SKIP existing adr/README.md"
fi

CONFIG="$TARGET/openspec/config.yaml"
if [[ -e "$CONFIG" && "$FORCE_CONFIG" == "0" ]]; then
  echo "SKIP existing openspec/config.yaml"
  echo "NOTE: review whether to set schema: intent-driven manually."
else
  echo "WRITE openspec/config.yaml"
  if [[ "$DRY_RUN" == "0" ]]; then
    mkdir -p "$TARGET/openspec"
    if [[ -e "$CONFIG" ]]; then cp "$CONFIG" "$CONFIG.bak.$(date +%Y%m%d%H%M%S)"; fi
    cat > "$CONFIG" <<'CONFIGEOF'
schema: intent-driven

context: |
  This project uses Codex-native intent-driven development with OpenSpec.
  Workflow: proposal -> specs -> design -> review -> adr -> test-plan -> tasks.
  Codex reads CONSTITUTION.md and ARCHITECTURE.md as project context; OpenSpec CLI does not.

rules:
  proposal:
    - Draft proposal.md from user intent and project context.
  specs:
    - Use OpenSpec delta sections and Gherkin-style scenarios in Markdown.
  design:
    - Use C4-style diagrams for non-trivial boundaries or explain why none is needed; account for ARCHITECTURE.md and in-force ADRs.
  review:
    - Use grill-with-docs to record mandatory context-aware review before ADR.
  adr:
    - Durable ADRs live in top-level adr/ and are append-only; update ARCHITECTURE.md when current architecture changes.
  test-plan:
    - Map requirements and scenarios to TDD or the strongest verification-first substitute before tasks.
  tasks:
    - Create dependency-ordered checkbox tasks based on proposal/specs/design/review/ADR/test-plan.
CONFIGEOF
  fi
fi

if [[ "$DRY_RUN" == "0" && -x "$TARGET/scripts/check-overlay" ]]; then
  chmod +x "$TARGET/scripts/check-overlay"
fi

echo "Install overlay complete. Next: cd '$TARGET' && openspec schema validate intent-driven && scripts/check-overlay"
