{"schemaVersion":1,"change":"$SMOKE_CHANGE","stage":"specs","verdict":"pass","costAvailable":true,"cost":{"total_cost_rub":0.67085093}}
{"schemaVersion":1,"change":"$SMOKE_CHANGE","stage":"design","verdict":"pass","costAvailable":false,"cost":{}}
JSONL
ARTIFACT_REVIEW_COST_SUMMARY_JSON="$(scripts/openspec-artifact-review --cost-summary --change "$SMOKE_CHANGE" 2>/tmp/check-overlay-artifact-cost-summary.err)" || {
  cat /tmp/check-overlay-artifact-cost-summary.err >&2
  rm -f "$ARTIFACT_REVIEW_TMP_CONFIG" "$ARTIFACT_REVIEW_PARSE_SAMPLE"
  fail "artifact review" "cost-summary helper failed"
}
ARTIFACT_REVIEW_COST_SUMMARY_JSON="$ARTIFACT_REVIEW_COST_SUMMARY_JSON" python3 - <<'PY' || fail "artifact review" "cost-summary result is invalid"
import json, os
obj = json.loads(os.environ['ARTIFACT_REVIEW_COST_SUMMARY_JSON'])
if obj.get('source') != 'ledger':
    raise SystemExit(f"cost summary did not prefer invocation ledger: {obj!r}")
if obj.get('reviewCount') != 3 or obj.get('invocationCount') != 3 or obj.get('costedReviewCount') != 2 or obj.get('missingCostCount') != 1:
    raise SystemExit(f"unexpected counts: {obj!r}")
if abs(obj.get('totalCostRub', -1) - 1.30625318) > 1e-12:
    raise SystemExit(f"unexpected totalCostRub: {obj!r}")
if obj.get('totalCostRubDisplayRu') != '1,31 ₽':
    raise SystemExit(f"unexpected rounded display total: {obj!r}")
PY
pass "artifact review" "cost-summary aggregates invocation ledger costs with rounded display totals without contacting the provider"

cat > "$SMOKE_DIR/reviews/design-artifact-review.json" <<JSON
{"schemaVersion":1,"change":"$SMOKE_CHANGE","stage":"design","verdict":"warn","mustFix":["Add rollback handling"],"shouldFix":["Mention status localization"],"warnings":["Double-check terminology"],"questions":["Can this be answered from repo context?"]}
JSON
set +e
