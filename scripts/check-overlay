}
ARTIFACT_REVIEW_CLOSED_DISPOSITION_JSON="$ARTIFACT_REVIEW_CLOSED_DISPOSITION_JSON" python3 - <<'PY' || fail "artifact review" "closed disposition result is invalid"
import json, os
obj = json.loads(os.environ['ARTIFACT_REVIEW_CLOSED_DISPOSITION_JSON'])
if obj.get('openFindingCount') != 0 or obj.get('userBlockedCount') != 0:
    raise SystemExit(f"unexpected open counts: {obj!r}")
if obj.get('findingCount') != 4 or obj.get('dispositionedFindingCount') != 4:
    raise SystemExit(f"unexpected disposition counts: {obj!r}")
PY
pass "artifact review" "disposition-summary blocks unresolved findings and accepts closed findings without contacting the provider"

rm -f "$ARTIFACT_REVIEW_TMP_CONFIG" "$ARTIFACT_REVIEW_PARSE_SAMPLE"

APPLY_JSON="$(openspec instructions apply --change "$SMOKE_CHANGE" --json 2>/tmp/check-overlay-apply.err)" || {
  cat /tmp/check-overlay-apply.err >&2
  fail "generated skill" "apply instructions failed"
}
APPLY_JSON="$APPLY_JSON" python3 - <<'PY' || fail "generated skill" "apply context is missing required intent-driven files"
import json, os
obj = json.loads(os.environ['APPLY_JSON'])
expected = ['proposal', 'specs', 'grill', 'design', 'design-review', 'adr', 'test-plan', 'tasks']
ctx = obj.get('contextFiles') or {}
missing = [key for key in expected if not ctx.get(key)]
if missing:
    raise SystemExit(f"missing context keys: {missing!r}")
if obj.get('progress', {}).get('total') != 1:
    raise SystemExit(f"unexpected progress={obj.get('progress')!r}")
PY
pass "generated skill" "apply context includes proposal/specs/grill/design/design-review/adr/test-plan/tasks"

echo "✓ Overlay check complete"
