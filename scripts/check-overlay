JSON
ARTIFACT_REVIEW_CLOSED_DISPOSITION_JSON="$(scripts/openspec-artifact-review --disposition-summary --change "$SMOKE_CHANGE" --stage design 2>/tmp/check-overlay-artifact-closed-disposition.err)" || {
