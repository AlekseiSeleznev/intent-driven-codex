    {"source":"shouldFix","index":0,"status":"deferred","reason":"Будет проверено в tasks.md","target":"openspec/changes/$SMOKE_CHANGE/tasks.md"},
    {"source":"warnings","index":0,"status":"non_actionable","reason":"Терминология подтверждена в CONTEXT.md"},
    {"source":"questions","index":0,"status":"non_actionable","reason":"Ответ найден в проектном контексте"}
  ]
