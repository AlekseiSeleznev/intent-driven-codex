# Example local secrets file for Intent-Driven Codex projects.
# Copy to .secrets.local.env and fill values locally.
# Do not commit .secrets.local.env.
# Keep all assignments in this example empty or placeholder-only.

# External system example variables. Rename per CONSTITUTION.md.
EXAMPLE_API_URL=
EXAMPLE_API_USERNAME=
EXAMPLE_API_PASSWORD=
EXAMPLE_API_TOKEN=

# MCP or connector variables if a local tool requires them.
MCP_SERVER_URL=
MCP_SERVER_TOKEN=
GITHUB_TOKEN=
